import ferozcompleto.*


object historiaUno {
	method hUno() {
		feroz.correr()
		feroz.correr()
		feroz.comer(abuelita)
		canasta.perderManzana()
		feroz.comer(caperucita)
		cazador.cazar()
		return feroz.estaSaludable()
	}
}

object historiaDos {
	method hDos() {
		feroz.correr()
		feroz.correr()
		feroz.comer(abuelita)
		canasta.perderManzana()
		feroz.comer(caperucita)
		feroz.comer(cazador)
		return feroz.estaSaludable()
	}
}